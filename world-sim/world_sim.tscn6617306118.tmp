[sub_resource type="GDScript" id="GDScript_d0b03"]
script/source = "extends Control

var function : Function
var points : int = 80
var chart : Chart

func _ready() -> void:
	var chart_scene: PackedScene = load(\"res://addons/easy_charts/control_charts/chart.tscn\")
	chart = chart_scene.instantiate()
	add_child(chart)
	
	function = Function.new(
		range(points),# The function's X-values
		init_vals(0, points), # The function's Y-values
		\"Supply\",
		{
			type = Function.Type.LINE,
			marker = Function.Marker.NONE,
			color = Color(\"#36a2eb\"),
		}
	)

	var cp := ChartProperties.new()
	cp.title = \"Example chart\"
	cp.show_legend = true
	cp.interactive = true
	
	chart.plot([function], cp)
	tick()

func init_vals(value : float, amount: int) -> Array[float]:
	var vals : Array[float] = []
	for i in range(amount):
		vals.append(value)
	return vals

func tick():
	function.add_point(float(points), randf())
	function.remove_point(0)
	points += 1
	chart.queue_redraw()
	
	await get_tree().create_timer(0.3).timeout
	tick()
"

